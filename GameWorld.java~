import java.util.*;
public class GameWorld {
  private GameLocations locations;
  private ArrayList<ArrayList<Location>> paths;

  
  public GameWorld(GameLocations input) { 
    this.locations = input;
    this.paths = new ArrayList<ArrayList<Location>>();

  }
  
  
  private ArrayList<Location> destCompiler(Location input){
    ArrayList<Location> compiled = new ArrayList<Location>();
    for(Location x: locations.directDestinations(input)){
      if(x.equals(input) == false){
        compiled.add(x);
      }
    }
    return compiled;
  }
  
//_____________________________________________________________________________________________________________________
//currently: all paths are the right size. why does loc3 keep getting slipped in?
  public void printPaths(Location current, Location destination){
    int numpaths = 1;
    if(current.equals(destination)){
      System.out.println("Path " + numpaths + ": " + current.toString());
    }
    else if (destCompiler(current).indexOf(destination) != -1){
      System.out.println("Path " + numpaths + ": " + current.toString() +
                         "--" + locations.distanceIs(current, destination) + "->" + destination.toString());
    }
    else{
      paths = new ArrayList<ArrayList<Location>>();
      ArrayList<Location> path = new ArrayList<Location>();
      path.add(current);
      findAllPaths(current, destination, path);
      for(int i = 0; i < paths.size(); ++i){
        System.out.print("Path " + numpaths + ": ");
        //System.out.print(paths.size());
        numpaths += 1;
        for(int j = 0; j < paths.get(i).size()-1; ++j){
          System.out.print(paths.get(i).get(j).toString() + "--" + locations.distanceIs(paths.get(i).get(j), paths.get(i).get(j+1)) + "->");

        }
        System.out.println(paths.get(i).get(paths.get(i).size()-1).toString());
      }
    }
    
  }
  
  public void findAllPaths(Location current, Location destination, ArrayList<Location> path){
    if(current.equals(destination) == true){
      paths.add(path);      
    }
    else{
      ArrayList<Location> newpath = new ArrayList<Location>(path);
      for(Location x: locations.directDestinations(current)){
        if(path.indexOf(x) == -1){
          newpath.add(x);
          findAllPaths(x, destination, newpath);
        }
      }
    }
  }
}
